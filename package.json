  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheAlexLichter/godox-tl.git"
  },
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "changelog": "changelogithub --output CHANGELOG.md",
