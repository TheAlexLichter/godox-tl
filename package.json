  "private": true,
  "description": "Monorepo for Godox TL30 BLE control (core, CLI, mesh transport, Homebridge plugin).",
  "homepage": "https://github.com/TheAlexLichter/godox-tl#readme",
  "bugs": {
    "url": "https://github.com/TheAlexLichter/godox-tl/issues"
