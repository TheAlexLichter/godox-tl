    "bluetooth",
    "godox",
    "godox-tl",
    "homebridge",
    "homebridge-plugin",
    "homekit",
    "mesh",
    "sig-mesh",
    "tl30"
  ],
  "homepage": "https://github.com/TheAlexLichter/godox-tl#readme",
  "bugs": {
    "url": "https://github.com/TheAlexLichter/godox-tl/issues"
  },
  "license": "MIT",
  "author": "Alexander Lichter <npm@lichter.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheAlexLichter/godox-tl.git"
  },
  "files": [
    "src",
    "dist",
    "config.schema.json"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack"
  },
  "dependencies": {
